public class HelloApp {
    public static void main(String[] args) {

        // Case 1: No arguments
        if (args.length == 0) {
            System.out.println("Hello, World!");
        } else {

            // Join all names with comma and space
            String names = String.join(", ", args);

            // Print result
            System.out.println("Hello, " + names + "!");
        }
    }
}
